{
  "manifest_version": 3,
  "name": "AI - Janival és Krisszel",
  "description": "Friss posztok, mentett Facebook-bejegyzések és Chrome beépített AI chat egy side panelben.",
  "version": "0.3.5",
  "update_url": "https://raw.githubusercontent.com/arlinamid/ai-janival-es-krisszel-plugin/master/updates.xml",
  "minimum_chrome_version": "138",
  "permissions": ["sidePanel", "storage", "clipboardWrite", "tabs", "alarms"],
  "host_permissions": [
    "https://www.facebook.com/*",
    "https://web.facebook.com/*",
    "http://www.ai-janival-es-krisszel.hu/*",
    "https://www.ai-janival-es-krisszel.hu/*"
  ],
  "background": {
    "service_worker": "background.js",
    "type": "module"
  },
  "content_scripts": [
    {
      "matches": ["https://www.facebook.com/*", "https://web.facebook.com/*"],
      "js": ["fb-saver-content.js"],
      "css": ["fb-saver-content.css"],
      "run_at": "document_idle"
    }
  ],
  "web_accessible_resources": [
    {
      "resources": ["profile_image.jpg", "icon.png"],
      "matches": ["https://www.facebook.com/*", "https://web.facebook.com/*"]
    }
  ],
  "icons": {
    "16": "icon.png",
    "32": "icon.png",
    "48": "icon.png",
    "128": "icon.png"
  },
  "side_panel": {
    "default_path": "sidepanel.html"
  },
  "action": {
    "default_title": "AI - Janival és Krisszel",
    "default_icon": {
      "16": "icon.png",
      "32": "icon.png",
      "48": "icon.png",
      "128": "icon.png"
    }
  }
}
