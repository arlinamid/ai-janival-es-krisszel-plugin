{
  "manifest_version": 3,
  "name": "AI - Janival és Krisszel",
  "description": "Friss posztok, mentett Facebook-bejegyzések és AI asszisztens egy oldalsávban.",
  "version": "0.4.7",
  "browser_specific_settings": {
    "gecko": {
      "id": "ai-janival-krisszel@plugin",
      "strict_min_version": "121.0"
    }
  },
  "permissions": ["storage", "clipboardWrite", "tabs", "alarms"],
  "host_permissions": [
    "https://www.facebook.com/*",
    "https://web.facebook.com/*",
    "http://www.ai-janival-es-krisszel.hu/*",
    "https://www.ai-janival-es-krisszel.hu/*",
    "http://ai-janival-es-krisszel.hu/*",
    "https://ai-janival-es-krisszel.hu/*"
  ],
  "background": {
    "scripts": ["background.js"]
  },
  "content_security_policy": {
    "extension_pages": "script-src 'self'; object-src 'self'; connect-src http://ai-janival-es-krisszel.hu https://ai-janival-es-krisszel.hu http://www.ai-janival-es-krisszel.hu https://www.ai-janival-es-krisszel.hu https://api.github.com;"
  },
  "content_scripts": [
    {
      "matches": ["https://www.facebook.com/*", "https://web.facebook.com/*"],
      "js": ["fb-saver-content.js"],
      "css": ["fb-saver-content.css"],
      "run_at": "document_idle"
    }
  ],
  "web_accessible_resources": [
    {
      "resources": ["profile_image.jpg", "icon.png"],
      "matches": ["https://www.facebook.com/*", "https://web.facebook.com/*"]
    }
  ],
  "icons": {
    "16": "icon.png",
    "32": "icon.png",
    "48": "icon.png",
    "128": "icon.png"
  },
  "sidebar_action": {
    "default_panel": "sidepanel.html",
    "default_title": "AI - Janival és Krisszel",
    "default_icon": {
      "16": "icon.png",
      "32": "icon.png",
      "48": "icon.png",
      "128": "icon.png"
    }
  },
  "action": {
    "default_title": "AI - Janival és Krisszel",
    "default_icon": {
      "16": "icon.png",
      "32": "icon.png",
      "48": "icon.png",
      "128": "icon.png"
    }
  }
}
